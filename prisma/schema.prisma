generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String       @id @default(uuid()) @db.Uuid
  projectCode     String?      @unique @map("project_code")
  name            String
  city            String?
  zone            String?
  segment         String?
  type            String?
  currency        String?      @default("MAD")
  totalCost       Decimal?     @map("total_cost") @db.Decimal(18, 2)
  financingAmount Decimal?     @map("financing_amount") @db.Decimal(18, 2)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  evaluations     Evaluation[]

  @@map("pi_projects")
}

model ModelVersion {
  id            String            @id @default(uuid()) @db.Uuid
  code          String            @unique
  label         String?
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  domainWeights DomainWeight[]
  kpis          Kpi[]
  thresholds    KpiThreshold[]
  segmentAdjustments SegmentAdjustment[]
  zoneAdjustments    ZoneAdjustment[]
  d5Triggers         D5Trigger[]
  evaluations        Evaluation[]

  @@map("pi_model_versions")
}

model DomainWeight {
  id         String       @id @default(uuid()) @db.Uuid
  modelCode  String       @map("model_code")
  domainCode String       @map("domain_code")
  weight     Decimal      @db.Decimal(10, 4)

  modelVersion ModelVersion @relation(fields: [modelCode], references: [code], onDelete: Cascade)

  @@unique([modelCode, domainCode])
  @@map("pi_domain_weights")
}

model Kpi {
  id         String       @id @default(uuid()) @db.Uuid
  modelCode  String       @map("model_code")
  domainCode String       @map("domain_code")
  kpiCode    String       @map("kpi_code")
  label      String
  unit       String?
  valueType  String       @default("number") @map("value_type")
  direction  String       @default("higher_is_better")
  weight     Decimal      @default(1.0) @db.Decimal(10, 4)
  isActive   Boolean      @default(true) @map("is_active")

  modelVersion ModelVersion  @relation(fields: [modelCode], references: [code], onDelete: Cascade)

  @@unique([modelCode, kpiCode])
  @@map("pi_kpis")
}

model KpiThreshold {
  id         String       @id @default(uuid()) @db.Uuid
  modelCode  String       @map("model_code")
  kpiCode    String       @map("kpi_code")
  segment    String?
  zone       String?
  bandMin    Decimal?     @map("band_min") @db.Decimal(18, 4)
  bandMax    Decimal?     @map("band_max") @db.Decimal(18, 4)
  score      Decimal      @db.Decimal(10, 4)

  modelVersion ModelVersion @relation(fields: [modelCode], references: [code], onDelete: Cascade)

  @@map("pi_kpi_thresholds")
}

model SegmentAdjustment {
  id         String       @id @default(uuid()) @db.Uuid
  modelCode  String       @map("model_code")
  segment    String
  alpha      Decimal      @db.Decimal(10, 4)

  modelVersion ModelVersion @relation(fields: [modelCode], references: [code], onDelete: Cascade)

  @@unique([modelCode, segment])
  @@map("pi_segment_adjustments")
}

model ZoneAdjustment {
  id         String       @id @default(uuid()) @db.Uuid
  modelCode  String       @map("model_code")
  zone       String
  beta       Decimal      @db.Decimal(10, 4)

  modelVersion ModelVersion @relation(fields: [modelCode], references: [code], onDelete: Cascade)

  @@unique([modelCode, zone])
  @@map("pi_zone_adjustments")
}

model D5Trigger {
  id          String       @id @default(uuid()) @db.Uuid
  modelCode   String       @map("model_code")
  triggerCode String       @map("trigger_code")
  label       String
  severity    String
  malus       Decimal      @default(0) @db.Decimal(10, 4)

  modelVersion ModelVersion @relation(fields: [modelCode], references: [code], onDelete: Cascade)

  @@unique([modelCode, triggerCode])
  @@map("pi_d5_triggers")
}

model Evaluation {
  id             String       @id @default(uuid()) @db.Uuid
  projectId      String       @map("project_id") @db.Uuid
  modelCode      String       @map("model_code")
  status         String       @default("draft")
  inputs         Json         @default("{}")
  results        Json         @default("{}")
  finalScore     Decimal?     @map("final_score") @db.Decimal(10, 4)
  grade          String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modelVersion   ModelVersion @relation(fields: [modelCode], references: [code], onDelete: Restrict)

  @@index([projectId], map: "idx_pi_eval_project")
  @@index([modelCode], map: "idx_pi_eval_model")
  @@map("pi_evaluations")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id") @db.Uuid
  action     String
  actor      String?
  oldValue   Json?     @map("old_value")
  newValue   Json?     @map("new_value")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("pi_audit_log")
}
